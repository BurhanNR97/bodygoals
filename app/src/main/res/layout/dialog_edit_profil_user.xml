<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/bg_card_login">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Edit Profil"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/edEditNama"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Nama lengkap"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_input"
            android:inputType="textPersonName" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jenis Kelamin"
            android:textStyle="bold"
            android:textColor="#374151"
            android:layout_marginTop="14dp" />

        <RadioGroup
            android:id="@+id/rgEditJenisKelamin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="@drawable/bg_input"
            android:layout_marginTop="6dp">

            <RadioButton
                android:id="@+id/rbEditLaki"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Laki-laki" />

            <RadioButton
                android:id="@+id/rbEditPerempuan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Perempuan" />
        </RadioGroup>

        <EditText
            android:id="@+id/edEditTglLahir"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Tanggal lahir"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_input"
            android:inputType="none"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginTop="14dp" />

        <EditText
            android:id="@+id/edEditTelp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Nomor telepon"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_input"
            android:inputType="phone"
            android:layout_marginTop="14dp" />

        <EditText
            android:id="@+id/edEditAlamat"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:hint="Alamat"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:gravity="top"
            android:background="@drawable/bg_input"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:maxLines="3"
            android:layout_marginTop="14dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <EditText
            android:layout_marginRight="5dp"
            android:id="@+id/edEditTB"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="Tinggi Badan"
            android:layout_weight="1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_input"
            android:inputType="numberSigned"
            android:layout_marginTop="14dp" />

        <EditText
            android:layout_marginLeft="5dp"
            android:id="@+id/edEditBB"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="Berat Badan"
            android:layout_weight="1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_input"
            android:inputType="phone"
            android:layout_marginTop="14dp" />

    </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="18dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBatalEditProfil"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Batal"
                android:textColor="#374151"
                android:background="@drawable/bg_input"
                android:layout_marginEnd="6dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSimpanEditProfil"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Simpan"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_button_orange"
                android:layout_marginStart="6dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>