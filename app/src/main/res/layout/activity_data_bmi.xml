<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainDataBMI"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F8FA">

    <RelativeLayout
        android:id="@+id/headerDataBMI"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_header_green"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_alignParentTop="true">

        <ImageView
            android:id="@+id/btnBackDataBMI"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Referensi Skala BMI"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnAddDataBMI"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_add"
            app:tint="#FFFFFF" />

    </RelativeLayout>

    <TextView
        android:id="@+id/tvJumlahDataBMI"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Menampilkan 0 data"
        android:textColor="#666666"
        android:textSize="13sp"
        android:layout_marginTop="10dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvKosongBMI"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Data referensi belum tersedia"
        android:textColor="#999999"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="40dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDataBMI"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>