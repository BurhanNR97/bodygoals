<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainRekomendasi"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".user.Rekomendasi">

    <RelativeLayout
        android:id="@+id/headerRekomendasi"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_header_green"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBackRekomendasi"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Rekomendasi Makanan"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <ScrollView
        android:fillViewport="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/headerRekomendasi">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvJudulCardRekomendasi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Catatan Hari Ini"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvTanggalCatatan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Input berat badan dan menu harianmu"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvStatusInputHarian"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Belum lengkap"
                            android:textColor="@color/user_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Tinggi dan Berat Badan -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="12dp">

                        <!-- Tinggi Badan -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_card_white"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tinggi Badan"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"/>

                            <TextView
                                android:id="@+id/tvTinggiHariIni"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="- cm"
                                android:textColor="@color/text_primary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- Berat Badan Hari Ini -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_card_white"
                            android:padding="12dp"
                            android:layout_marginStart="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Berat Hari Ini"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"/>

                            <TextView
                                android:id="@+id/tvBeratHariIni"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="- kg"
                                android:textColor="@color/text_primary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- BMI dan Kategori -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_card_white"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BMI"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"/>

                            <TextView
                                android:id="@+id/tvBMIHariIni"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="@color/text_primary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_card_white"
                            android:padding="12dp"
                            android:layout_marginStart="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kategori"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"/>

                            <TextView
                                android:id="@+id/tvKategoriBMIHariIni"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="@color/user_primary"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginTop="10dp"/>
                        </LinearLayout>
                    </LinearLayout>


                    <!-- Riwayat Penyakit -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_white"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Riwayat Penyakit"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/tvPenyakitHariIni"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Tidak ada"
                                    android:textColor="@color/text_primary"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/btnEditPenyakit"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:text="Ubah"
                                android:textColor="@color/user_primary"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_card_white" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Riwayat penyakit digunakan untuk menyesuaikan batas gula, garam, lemak, protein, dan serat."
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- Ringkasan Menu Harian -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_white"
                        android:padding="12dp">

                        <!-- Sarapan -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp">

                            <TextView
                                android:layout_width="95dp"
                                android:layout_height="wrap_content"
                                android:text="Sarapan"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvSarapanHariIni"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="-"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"/>

                            <TextView
                                android:id="@+id/tvKaloriSarapan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 kkal"
                                android:textColor="@color/text_hint"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"/>

                        <!-- Makan Siang -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp">

                            <TextView
                                android:layout_width="95dp"
                                android:layout_height="wrap_content"
                                android:text="Makan Siang"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvMakanSiangHariIni"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="-"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"/>

                            <TextView
                                android:id="@+id/tvKaloriMakanSiang"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 kkal"
                                android:textColor="@color/text_hint"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"/>

                        <!-- Makan Malam -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp">

                            <TextView
                                android:layout_width="95dp"
                                android:layout_height="wrap_content"
                                android:text="Makan Malam"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvMakanMalamHariIni"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="-"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"/>

                            <TextView
                                android:id="@+id/tvKaloriMakanMalam"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 kkal"
                                android:textColor="@color/text_hint"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"/>

                        <!-- Snack -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp">

                            <TextView
                                android:layout_width="95dp"
                                android:layout_height="wrap_content"
                                android:text="Snack"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvSnackHariIni"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="-"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"/>

                            <TextView
                                android:id="@+id/tvKaloriSnack"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 kkal"
                                android:textColor="@color/text_hint"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="8dp"/>

                        <!-- Jumlah Kalori -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Jumlah Kalori Hari Ini"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvTotalKaloriHariIni"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 kkal"
                                android:textColor="@color/user_primary"
                                android:textSize="15sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Tombol Aksi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:id="@+id/btnSaranMenu"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:gravity="center"
                            android:text="Saran Menu"
                            android:textColor="@color/user_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_card_white"/>

                        <TextView
                            android:id="@+id/btnIsiDataHarian"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:gravity="center"
                            android:text="Isi Data"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/btn_biru"/>

                        <TextView
                            android:id="@+id/btnUlangiRekomendasi"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:gravity="center"
                            android:text="Ulangi isian"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/btn_merah"
                            android:visibility="gone"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/llRekomendasi7Hari"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="20dp"
                android:visibility="gone"/>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
