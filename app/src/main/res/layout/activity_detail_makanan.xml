<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainDetailMakanan"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F8FA">

    <RelativeLayout
        android:id="@+id/headerDataPasien"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_header_green"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_alignParentTop="true">

        <ImageView
            android:id="@+id/btnBackDetailMakanan"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Detail Data Makanan"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:visibility="gone"
            android:id="@+id/btnAddDetailMakanan"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_add"
            app:tint="#FFFFFF" />

    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvDetailNamaMakanan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nama Makanan"
                android:textColor="#222222"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvDetailKategoriMakanan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kategori"
                android:textColor="#0B7A3B"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/bg_badge_green"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvDetailPorsi"
                style="@style/TextDetailValue" />

            <TextView
                android:id="@+id/tvDetailKkal"
                style="@style/TextDetailValue" />

            <TextView
                android:id="@+id/tvDetailProtein"
                style="@style/TextDetailValue" />

            <TextView
                android:id="@+id/tvDetailKarbohidrat"
                style="@style/TextDetailValue" />

            <TextView
                android:id="@+id/tvDetailEnergi"
                style="@style/TextDetailValue" />

            <TextView
                android:id="@+id/tvDetailAir"
                style="@style/TextDetailValue" />

            <TextView
                android:id="@+id/tvDetailLemak"
                style="@style/TextDetailValue" />

            <TextView
                android:id="@+id/tvDetailSerat"
                style="@style/TextDetailValue" />

            <TextView
                android:id="@+id/tvDetailGula"
                style="@style/TextDetailValue" />

            <TextView
                android:id="@+id/tvDetailNatrium"
                style="@style/TextDetailValue" />

            <TextView
                android:id="@+id/tvDetailKeterangan"
                style="@style/TextDetailValue" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:background="#FFFFFF">

        <TextView
            android:id="@+id/btnUbahMakanan"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Ubah"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/btn_biru"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btnHapusMakanan"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Hapus"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/btn_merah"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>