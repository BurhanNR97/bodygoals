<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainRulesPenyakit"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F8FA">

    <RelativeLayout
        android:id="@+id/headerDataPasien"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_header_green"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_alignParentTop="true">

        <ImageView
            android:id="@+id/btnBackRulesPenyakit"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Rules Penyakit"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:visibility="gone"
            android:id="@+id/btnAddRulesPenyakit"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_add"
            app:tint="#FFFFFF" />

    </RelativeLayout>

    <EditText
        android:id="@+id/edtCariRulesPenyakit"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="16dp"
        android:hint="Cari nama penyakit atau kata kunci..."
        android:paddingHorizontal="14dp"
        android:background="@drawable/bg_edittext" />

    <TextView
        android:id="@+id/tvJumlahRulesPenyakit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Menampilkan 0 data"
        android:textColor="#666666"
        android:textSize="13sp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvKosongRulesPenyakit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Data rules penyakit belum tersedia"
        android:textColor="#999999"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="40dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRulesPenyakit"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>