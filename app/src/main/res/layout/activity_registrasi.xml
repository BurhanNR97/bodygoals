<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F6A623"
    android:id="@+id/mainRegistrasi">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_login"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="HALAMAN REGISTRASI"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1F2937"
                    android:gravity="center"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NIK"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginTop="22dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inNik"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="NIK"
                    app:hintEnabled="false"
                    android:background="@drawable/bg_input">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edNik"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_input"
                        android:hint="Masukkan NIK"
                        android:textSize="14sp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:inputType="numberSigned"
                        android:layout_marginTop="8dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nama"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginTop="22dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inNama"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Nama"
                    app:hintEnabled="false"
                    android:background="@drawable/bg_input">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edNama"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_input"
                        android:hint="Masukkan Nama"
                        android:textSize="14sp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:inputType="textPersonName"
                        android:layout_marginTop="8dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Jenis Kelamin -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Jenis Kelamin"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginTop="22dp" />

                <RadioGroup
                    android:id="@+id/rgJenisKelamin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:padding="8dp"
                    android:background="@drawable/bg_input">

                    <RadioButton
                        android:id="@+id/rbLaki"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Laki-laki"
                        android:textColor="#374151"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/rbPerempuan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Perempuan"
                        android:textColor="#374151"
                        android:textSize="14sp" />
                </RadioGroup>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tanggal Lahir"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginTop="22dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inTglLahir"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Tanggal Lahir"
                    app:hintEnabled="false"
                    android:background="@drawable/bg_input">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edTglLahir"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_input"
                        android:hint="Pilih tanggal lahir"
                        android:textSize="14sp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:focusable="false"
                        android:clickable="true"
                        android:inputType="none"
                        android:layout_marginTop="8dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nomor Telepon"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginTop="22dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inTelp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Nomor Telepon"
                    app:hintEnabled="false"
                    android:background="@drawable/bg_input">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edTelp"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_input"
                        android:hint="Masukkan nomor telepon"
                        android:textSize="14sp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:inputType="phone"
                        android:layout_marginTop="8dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alamat"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginTop="22dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inAlamat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Alamat"
                    app:hintEnabled="false"
                    android:background="@drawable/bg_input">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edAlamat"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:background="@drawable/bg_input"
                        android:hint="Masukkan alamat"
                        android:textSize="14sp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:gravity="top"
                        android:minLines="2"
                        android:maxLines="3"
                        android:inputType="textMultiLine"
                        android:layout_marginTop="8dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginTop="22dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Email"
                    app:hintEnabled="false"
                    android:background="@drawable/bg_input">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edEmail"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_input"
                        android:hint="Masukkan email"
                        android:textSize="14sp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:inputType="textEmailAddress"
                        android:layout_marginTop="8dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginTop="18dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:endIconMode="password_toggle"
                    android:hint="Password"
                    app:hintEnabled="false"
                    android:background="@drawable/bg_input">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edPassword"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_input"
                        android:hint="Masukkan password"
                        android:textSize="14sp"
                        android:inputType="textPassword"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"/>

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Konfirmasi Password"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginTop="18dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inKonfirPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:endIconMode="password_toggle"
                    android:hint="Konfirmasi Password"
                    app:hintEnabled="false"
                    android:background="@drawable/bg_input">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edKonfirPassword"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_input"
                        android:hint="Masukkan password"
                        android:textSize="14sp"
                        android:inputType="textPassword"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"/>

                </com.google.android.material.textfield.TextInputLayout>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDaftar"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="DAFTAR"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_orange"
                    android:layout_marginTop="18dp" />

                <TextView
                    android:id="@+id/tvKeLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sudah punya akun?\nMasuk disini"
                    android:textSize="16sp"
                    android:textColor="#6B7280"
                    android:gravity="center"
                    android:layout_marginTop="14dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>