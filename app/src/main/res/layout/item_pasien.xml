<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardPasien"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    card_view:cardCornerRadius="14dp"
    card_view:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/pasien_nik"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NIK Pasien"
            android:textColor="#222222"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pasien_nama"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nama pasien"
            android:textColor="#666666"
            android:textSize="13sp"
            android:layout_marginTop="3dp" />

        <TextView
            android:id="@+id/pasien_jk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jenis Kelamin"
            android:textColor="#666666"
            android:textSize="13sp"
            android:layout_marginTop="3dp" />

        <TextView
            android:id="@+id/pasien_tgl_lahir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tanggal Lahir"
            android:textColor="#666666"
            android:textSize="13sp"
            android:layout_marginTop="3dp" />

        <TextView
            android:id="@+id/pasien_alamat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alamat"
            android:textColor="#666666"
            android:textSize="13sp"
            android:layout_marginTop="3dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>